# ─── rg-alpha-engine environment ──────────────────────────────────────────────
# Copy to `.env` and fill in real values. Do not commit `.env`.

# ─── LLM (primary) ────────────────────────────────────────────────────────────
# DeepSeek is the default LLM. R1 (deepseek-reasoner) handles agent reasoning,
# V3 (deepseek-chat) handles cheap data parsing. See src/utils/llm_router.py.
DEEPSEEK_API_KEY=

# ─── Financial data (primary) ─────────────────────────────────────────────────
# Massive (formerly Polygon.io) — the default data provider for this project.
# Required scopes: Stocks Advanced (aggregates + news + reference) plus the
# Financials & Ratios expansion (income/balance/cash-flow/ratios endpoints).
MASSIVE_API_KEY=
MASSIVE_BASE_URL=https://api.polygon.io

# Set DATA_PROVIDER to switch backends without code changes.
#   massive  → use Massive/Polygon (default)
#   fds      → use financialdatasets.ai (requires FINANCIAL_DATASETS_API_KEY)
DATA_PROVIDER=massive

# ─── Financial data (fallback / legacy) ───────────────────────────────────────
FINANCIAL_DATASETS_API_KEY=

# ─── Optional LLM providers (unused unless you wire them per-agent) ───────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
OPENROUTER_API_KEY=

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
